# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (for Docker Compose)
POSTGRES_DB=iss_portal_db
POSTGRES_USER=iss_user
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql://iss_user:change-this-password@db:5432/iss_portal_db

# Timezone
TZ=America/New_York

# Field-level Encryption
# Generate with: docker-compose exec web python manage.py generate_encryption_key
# IMPORTANT: Keep this key secure - loss means data cannot be decrypted
FIELD_ENCRYPTION_KEY=

# =============================================================================
# Microsoft Entra Application Proxy SSO
# =============================================================================
# Set to True to enable single sign-on via Entra Application Proxy headers.
# Users must be pre-created with email matching their Entra UPN.
ENTRA_PROXY_AUTH_ENABLED=False

# The HTTP header containing the user's UPN (default works with Entra App Proxy)
# ENTRA_PROXY_AUTH_HEADER=HTTP_X_MS_CLIENT_PRINCIPAL_NAME

# Azure AD Tenant ID (for sign-out URL generation)
# AZURE_AD_TENANT_ID=your-tenant-id-here

# CSRF Trusted Origins - REQUIRED when behind Entra Application Proxy.
# Must include the external URL assigned by the Application Proxy.
# Example: CSRF_TRUSTED_ORIGINS=https://iss-portal-contoso.msappproxy.net
CSRF_TRUSTED_ORIGINS=

# SSL redirect - set to False when behind Entra App Proxy (it handles TLS).
# The proxy terminates HTTPS externally and forwards HTTP to this server.
SECURE_SSL_REDIRECT=False
